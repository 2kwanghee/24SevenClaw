#!/usr/bin/env bash
# {{ project_name }} — Linear 이슈 자동 처리 파이프라인
#
# webhook_server.py 또는 linear_watcher.py에서 호출됨.
# 사용법: bash scripts/run-pipeline.sh <issue-identifier>
# 예:    bash scripts/run-pipeline.sh 24S-5
#
# 흐름:
#   1. Linear에서 이슈 상세 조회
#   2. .ralph/fix_plan.md 생성
#   3. Linear 상태 → In Progress
#   4. 브랜치 생성 (ralph/<identifier>)
#   5. claude --dangerously-skip-permissions 실행
#   6. Linear 상태 → Done (성공) / In Review (실패)
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$PROJECT_DIR"

ISSUE_KEY="${1:-}"
if [[ -z "$ISSUE_KEY" ]]; then
  echo "Usage: $0 <issue-identifier>" >&2
  exit 1
fi

log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] [pipeline] $*"
}

# ── 중복 실행 방지 락 — webhook_server.py / linear_watcher.py와 동일 경로 사용 ──
LOCK_FILE="$PROJECT_DIR/.run/pipeline-${ISSUE_KEY}.lock"
mkdir -p "$PROJECT_DIR/.run"
if [[ -f "$LOCK_FILE" ]]; then
  _existing_pid=$(cat "$LOCK_FILE" 2>/dev/null || true)
  if [[ -n "$_existing_pid" ]] && kill -0 "$_existing_pid" 2>/dev/null; then
    log "SKIP: $ISSUE_KEY 이미 처리 중 (pid: $_existing_pid)"
    exit 0
  fi
  log "stale lock 정리: pid ${_existing_pid:-?} 종료됨"
  rm -f "$LOCK_FILE"
fi
( set -o noclobber; echo "$$" > "$LOCK_FILE" ) 2>/dev/null || {
  log "SKIP: $ISSUE_KEY — 락 획득 실패 (동시 진입 감지)"
  exit 0
}
trap 'rm -f "$LOCK_FILE"' EXIT

# ── 환경변수 로드 ──
# IFS='=' 방식 대신 BASH_REMATCH로 파싱 — 값에 '='가 포함돼도 잘리지 않음
if [[ -f "$PROJECT_DIR/.env" ]]; then
  while IFS= read -r _line; do
    [[ "$_line" =~ ^([A-Z_][A-Z0-9_]*)=(.*)$ ]] || continue
    _k="${BASH_REMATCH[1]}"
    _v="${BASH_REMATCH[2]}"
    # 따옴표 감싸진 값 제거 ("value" 또는 'value')
    _v="${_v#\"}" ; _v="${_v%\"}"
    _v="${_v#\'}" ; _v="${_v%\'}"
    export "$_k=$_v"
  done < <(grep -E '^[A-Z_][A-Z0-9_]*=' "$PROJECT_DIR/.env" 2>/dev/null)
fi

if [[ -z "${LINEAR_API_KEY:-}" || -z "${LINEAR_TEAM_ID:-}" ]]; then
  log "ERROR: .env에 LINEAR_API_KEY, LINEAR_TEAM_ID 필요"
  exit 1
fi

# ── Linear 이슈 상세 조회 ──
log "이슈 조회: $ISSUE_KEY"

ISSUE_JSON=$(python3 - "$ISSUE_KEY" "$LINEAR_API_KEY" "$LINEAR_TEAM_ID" <<'PYEOF'
import json, sys
from urllib.request import Request, urlopen

identifier, api_key, team_id = sys.argv[1], sys.argv[2], sys.argv[3]

query = """
query($teamId: ID!) {
  issues(
    filter: {
      team: { id: { eq: $teamId } }
      state: { name: { in: ["Todo", "In Progress"] } }
    }
    first: 50
  ) {
    nodes {
      id
      identifier
      title
      description
      state { id name }
    }
  }
}
"""
body = json.dumps({"query": query, "variables": {"teamId": team_id}}).encode()
req = Request("https://api.linear.app/graphql", data=body, method="POST")
req.add_header("Authorization", api_key)
req.add_header("Content-Type", "application/json")
with urlopen(req, timeout=15) as r:
    data = json.loads(r.read())

nodes = data.get("data", {}).get("issues", {}).get("nodes", [])
node = next((n for n in nodes if n["identifier"] == identifier), None)
print(json.dumps(node) if node else "{}")
PYEOF
) || ISSUE_JSON="{}"

ISSUE_ID=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('id',''))" "$ISSUE_JSON")
ISSUE_TITLE=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('title',''))" "$ISSUE_JSON")
ISSUE_DESC=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('description','') or '')" "$ISSUE_JSON")

if [[ -z "$ISSUE_ID" ]]; then
  log "ERROR: 이슈를 찾을 수 없습니다: $ISSUE_KEY"
  exit 1
fi

log "이슈 확인: [$ISSUE_KEY] $ISSUE_TITLE"

# ── fix_plan.md 생성 ──
mkdir -p "$PROJECT_DIR/.ralph/tasks"
TASK_FILE="$PROJECT_DIR/.ralph/tasks/${ISSUE_KEY}.md"

# description 내 체크박스를 일반 항목으로 정규화 (stop-hook 오판 방지)
SAFE_DESC=$(echo "$ISSUE_DESC" | sed 's/- \[ \] /- /g; s/- \[x\] /- /g')

cat > "$TASK_FILE" <<MDEOF
# Ralph Loop — 작업 큐 (Fix Plan)

> Claude가 이 파일을 읽고 미완료(\`- [ ]\`) 항목을 처리한다.
> 완료 시 \`- [x]\`로 표시하고 커밋한다.
> \`- [!]\`는 건너뛴 항목 (사유 기록 필수).

---

## P1: 기능 요구사항

- [ ] **${ISSUE_TITLE}**
$(if [[ -n "$SAFE_DESC" ]]; then echo "  > 요청사항: ${SAFE_DESC}"; fi)

---

## 진행 로그

| 시각 | 항목 | 상태 | 비고 |
|------|------|------|------|
MDEOF

cp "$TASK_FILE" "$PROJECT_DIR/.ralph/fix_plan.md"
log "fix_plan.md 생성 완료"

# ── Linear 상태 업데이트 헬퍼 ──
update_linear_state() {
  local issue_id="$1" state_name="$2" state_type="${3:-}"
  local _exit=0
  python3 - "$issue_id" "$state_name" "$state_type" "$LINEAR_API_KEY" "$LINEAR_TEAM_ID" <<'PYEOF' 2>&1 || _exit=$?
import json, sys
from urllib.request import Request, urlopen

issue_id, state_name, state_type, api_key, team_id = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5]

# 팀 상태 목록 조회 (type 필드 포함)
q = 'query($id: String!) { team(id: $id) { states { nodes { id name type } } } }'
body = json.dumps({"query": q, "variables": {"id": team_id}}).encode()
req = Request("https://api.linear.app/graphql", data=body, method="POST")
req.add_header("Authorization", api_key)
req.add_header("Content-Type", "application/json")
with urlopen(req, timeout=15) as r:
    data = json.loads(r.read())

states = data.get("data", {}).get("team", {}).get("states", {}).get("nodes", [])

# 이름 일치 우선, 없으면 type으로 폴백
state_id = next((s["id"] for s in states if s["name"].lower() == state_name.lower()), None)
if not state_id and state_type:
    state_id = next((s["id"] for s in states if s.get("type", "").lower() == state_type.lower()), None)
if not state_id:
    avail = ["{0}({1})".format(s["name"], s.get("type", "")) for s in states]
    print("ERROR: 상태 '{0}' 없음. 사용 가능: {1}".format(state_name, avail), file=sys.stderr)
    sys.exit(1)

m = 'mutation($id: String!, $sid: String!) { issueUpdate(id: $id, input: { stateId: $sid }) { success } }'
body = json.dumps({"query": m, "variables": {"id": issue_id, "sid": state_id}}).encode()
req = Request("https://api.linear.app/graphql", data=body, method="POST")
req.add_header("Authorization", api_key)
req.add_header("Content-Type", "application/json")
with urlopen(req, timeout=15) as r:
    result = json.loads(r.read())

if not result.get("data", {}).get("issueUpdate", {}).get("success"):
    print("ERROR: issueUpdate 실패: {0}".format(result), file=sys.stderr)
    sys.exit(1)
PYEOF
  [[ "$_exit" -eq 0 ]] || log "WARN: Linear 상태 업데이트 실패 ($state_name, exit: $_exit)"
}

# ── Linear 상태 → In Progress ──
update_linear_state "$ISSUE_ID" "In Progress" "started"
log "Linear: In Progress"

# ── 브랜치 생성 ──
BRANCH="ralph/${ISSUE_KEY}"
git checkout main 2>/dev/null || true
git pull origin main 2>/dev/null || true

if git branch --merged main 2>/dev/null | grep -q " $BRANCH$"; then
  log "이전 브랜치 삭제 후 재생성: $BRANCH"
  git branch -d "$BRANCH" 2>/dev/null || true
fi

git checkout -b "$BRANCH" 2>/dev/null || git checkout "$BRANCH" 2>/dev/null || {
  log "WARN: 브랜치 생성 실패 — main에서 작업 계속"
}

# ── Claude 구현 ──
CLAUDE_LOG="$PROJECT_DIR/logs/claude_${ISSUE_KEY}_$(date '+%Y%m%d_%H%M%S').log"
mkdir -p "$PROJECT_DIR/logs"

log "Claude 구현 시작 (로그: $CLAUDE_LOG)"
log "브랜치: $BRANCH"

# 스킬 파일이 있으면 ralph-loop 워크플로 참조, 없으면 인라인 지침 사용
SKILLS_FILE="{{ config_dir }}/skills/ralph-loop.md"
if [[ -f "$PROJECT_DIR/$SKILLS_FILE" ]]; then
  PROMPT="$(cat "$PROJECT_DIR/$SKILLS_FILE")

---

위 ralph-loop 워크플로에 따라 .ralph/fix_plan.md의 첫 번째 미완료 항목을 구현해줘.

이슈: $ISSUE_KEY — $ISSUE_TITLE
브랜치: $BRANCH

## 디렉토리 명명 규칙 (반드시 준수)
- 프론트엔드 코드는 반드시 \`front/\` 디렉토리에 생성
- 백엔드 코드는 반드시 \`backend/\` 디렉토리에 생성
- 프레임워크·프로젝트명 기반 디렉토리명 사용 금지 (예: clickeye-web, myapp 등)"
else
  PROMPT=".ralph/fix_plan.md의 첫 번째 미완료 항목(- [ ])을 구현해줘.

구현 완료 후:
1. fix_plan.md에서 해당 항목을 - [x]로 표시
2. 변경사항을 git commit (브랜치: $BRANCH)
3. 테스트가 있으면 실행하여 통과 확인

## 디렉토리 명명 규칙 (반드시 준수)
- 프론트엔드 코드는 반드시 \`front/\` 디렉토리에 생성
- 백엔드 코드는 반드시 \`backend/\` 디렉토리에 생성
- 프레임워크·프로젝트명 기반 디렉토리명 사용 금지 (예: clickeye-web, myapp 등)

이슈: $ISSUE_KEY — $ISSUE_TITLE"
fi

# ANTHROPIC_API_KEY를 unset — claude.ai 구독 세션 사용 (API 크레딧 차감 방지)
# Linear 등 다른 스크립트는 .env를 직접 읽으므로 영향 없음
unset ANTHROPIC_API_KEY

set +e
claude -p "$PROMPT" \
  --dangerously-skip-permissions \
  2>&1 | tee "$CLAUDE_LOG"
CLAUDE_EXIT="${PIPESTATUS[0]}"
set -e

if [[ "$CLAUDE_EXIT" -eq 0 ]]; then
  log "Claude 구현 완료"
  update_linear_state "$ISSUE_ID" "Done" "completed"
  log "Linear: Done"
else
  log "WARN: Claude 비정상 종료 (exit: $CLAUDE_EXIT)"
  update_linear_state "$ISSUE_ID" "In Review"
  log "Linear: In Review (수동 확인 필요)"
fi

log "파이프라인 완료: $ISSUE_KEY"
