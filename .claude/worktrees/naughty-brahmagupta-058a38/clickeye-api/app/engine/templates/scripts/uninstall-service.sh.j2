#!/usr/bin/env bash
# {{ project_name }} — systemd 사용자 서비스 제거
# 사용법: bash scripts/uninstall-service.sh
set -euo pipefail

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo ""
echo -e "${BOLD}🗑️  ClickEye 서비스 제거${NC}"
echo "============================================"

SYSTEMD_USER_DIR="$HOME/.config/systemd/user"
REMOVED=0

_stop_and_disable() {
  local svc="$1"
  if systemctl --user is-active "$svc" > /dev/null 2>&1; then
    systemctl --user stop "$svc" 2>/dev/null || true
  fi
  if systemctl --user is-enabled "$svc" > /dev/null 2>&1; then
    systemctl --user disable "$svc" 2>/dev/null || true
  fi
  if [[ -f "$SYSTEMD_USER_DIR/${svc}.service" ]]; then
    rm -f "$SYSTEMD_USER_DIR/${svc}.service"
    echo -e "   ${GREEN}✅ ${svc} 제거됨${NC}"
    REMOVED=$((REMOVED + 1))
  fi
}

_stop_and_disable clickeye-watcher
{% if has_linear %}
_stop_and_disable clickeye-webhook
{% endif %}

if [[ $REMOVED -gt 0 ]]; then
  systemctl --user daemon-reload
  echo -e "   ${GREEN}✅ daemon-reload 완료${NC}"
fi

echo ""
if [[ $REMOVED -eq 0 ]]; then
  echo -e "   ${YELLOW}⚠️  제거할 서비스가 없습니다 (이미 제거됨)${NC}"
else
  echo -e "╔═══════════════════════════════════════════╗"
  echo -e "║  ${GREEN}✅ 서비스 제거 완료${NC}                      ║"
  echo -e "╚═══════════════════════════════════════════╝"
fi
echo ""
