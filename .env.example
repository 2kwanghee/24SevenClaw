# 24SevenClaw 루트 환경변수 템플릿
# 사용법: cp .env.example .env 후 값 수정
# 주의: .env는 .gitignore에 등록되어 있으며 절대 커밋하지 말 것

# === Database ===
DATABASE_URL=postgresql+asyncpg://sevenclaw:devpassword@localhost:5432/sevenclaw
REDIS_URL=redis://localhost:6379

# === Auth / JWT ===
JWT_SECRET_KEY=change-this-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_SECRET=change-this-in-production
AUTH_URL=http://localhost:3000

# === API / Web ===
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=true

# === Agent ===
SEVENCLAW_AGENT_ID=
SEVENCLAW_AGENT_SECRET=
SEVENCLAW_LICENSE_KEY=
SEVENCLAW_CLOUD_WS_URL=wss://api.24sevenclaw.com
SEVENCLAW_HEARTBEAT_INTERVAL=30
SEVENCLAW_DATA_DIR=/data/sevenclaw

# === External API Keys ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
FIGMA_ACCESS_TOKEN=

# === Git / CI ===
GIT_TOKEN=

# === Linear (프로젝트 관리) ===
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# === Telegram (알림) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === FlowOps (자동화 파이프라인 설정) ===
FLOWOPS_AUTO_COMMIT=false
FLOWOPS_AUTO_MERGE=false
FLOWOPS_AUTO_PR=false
FLOWOPS_CODEX_REVIEW=false
FLOWOPS_GEMINI_PLAN=false
FLOWOPS_GPT_REVIEW=false
FLOWOPS_LINEAR_CONFIRM=false
FLOWOPS_LINEAR_REPORT=false
FLOWOPS_LINEAR_WATCHER=false
FLOWOPS_RALPH_STOP_HOOK=false
FLOWOPS_TELEGRAM=false
FLOWOPS_TODO_REMINDER=false
