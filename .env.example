# ClickEye 환경변수 템플릿
# cp .env.example .env 후 값을 채워 사용하세요.
# .env는 .gitignore에 등록되어 있으므로 커밋되지 않습니다.

# ── ClickEye API 서버 ──
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
REDIS_URL=redis://localhost:6379
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=true

# ── ClickEye Web ──
NEXT_PUBLIC_API_URL=http://localhost:8000
AUTH_SECRET=dev-auth-secret-change-in-production
AUTH_URL=http://localhost:3000

# ── ClickEye Agent ──
CLICKEYE_AGENT_ID=your-agent-id
CLICKEYE_AGENT_SECRET=your-agent-secret
CLICKEYE_LICENSE_KEY=your-license-key
CLICKEYE_CLOUD_WS_URL=ws://localhost:8000
CLICKEYE_HEARTBEAT_INTERVAL=30
CLICKEYE_DATA_DIR=/data/clickeye

# ── Flow-Ops 파이프라인 (필수: Linear) ──
LINEAR_API_KEY=lin_api_YOUR_KEY_HERE
LINEAR_TEAM_ID=your-team-uuid
# 멀티팀 사용 시:
# LINEAR_TEAM_ID_DEV=your-dev-team-uuid
# LINEAR_TEAM_ID_DOCS=your-docs-team-uuid

# ── 선택: 외부 AI 코드 리뷰 ──
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── 선택: Telegram 알림 ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 선택: GitHub Token ──
GIT_TOKEN=

# ── 선택: Figma MCP ──
FIGMA_ACCESS_TOKEN=

# ── 선택: Anthropic API ──
ANTHROPIC_API_KEY=

# ── Flow-Ops 모듈 토글 (true/false) ──
FLOWOPS_LINEAR_WATCHER=true
FLOWOPS_LINEAR_REPORT=true
FLOWOPS_LINEAR_CONFIRM=true
FLOWOPS_AUTO_PR=true
FLOWOPS_AUTO_MERGE=true
FLOWOPS_AUTO_COMMIT=true
FLOWOPS_GPT_REVIEW=false
FLOWOPS_RALPH_STOP_HOOK=true
FLOWOPS_TELEGRAM=true
FLOWOPS_TODO_REMINDER=true
# 기획 단계: 메타프롬프트 정제(관측형 사전 정제)가 기본. false면 Gemini 레거시로 폴백.
FLOWOPS_METAPROMPT=true
FLOWOPS_GEMINI_PLAN=false
FLOWOPS_CODEX_REVIEW=true

# 거버넌스 게이트(머지 직전 권위 검증+위험분류, SSOT: scripts/pre_merge_gate.py).
# 마스터 off면 게이트 전체 우회 → 기존 동작 동일(회귀 0).
FLOWOPS_GOVERNANCE=true
FLOWOPS_GOVERNANCE_CONTRACT=true     # contract-drift(API 계약면↔openapi.json/generated 동반) 차단
FLOWOPS_GOVERNANCE_TICKET=true       # ticket-ref(브랜치 ralph/<KEY> 형태 검증, 키 없으면 skip)
FLOWOPS_GOVERNANCE_TRACE=true        # plan-trace(refined/PLAN 연관성 권고, 비블로킹, 산출물 없으면 skip)
FLOWOPS_GOVERNANCE_RISK_DEMOTE=true  # HIGH(contracts/infra/auth/보안)→직접머지 금지·PR 강등
FLOWOPS_GOVERNANCE_PROMOTE=true      # direct-merge 고복잡도 산출물을 logs/governance/<KEY>/ 로 승격
# 승격 복잡도 프록시 임계치(둘 중 하나 초과 시 승격)
FLOWOPS_PROMOTE_MIN_FILES=10
FLOWOPS_PROMOTE_MIN_LINES=400
# 거버넌스 HTTP 컨트롤 플레인 경유(선택). 값이 있으면 게이트가 이 서비스의
# POST /api/v1/governance/evaluate 로 판정하고, 비200/타임아웃/연결실패 시 WARN 후
# 로컬 shim(scripts/pre_merge_gate.py)으로 폴백한다. **빈 값(미설정)=로컬 판정(회귀 0)**.
# (is_enabled 토글이 아니라 "URL 존재 여부"가 스위치 — 미설정이 곧 로컬이어야 하므로.)
FLOWOPS_GOVERNANCE_SERVICE_URL=
# curl 타임아웃(초). 미설정 시 기본 10.
FLOWOPS_GOVERNANCE_SERVICE_TIMEOUT=10
# 머신-투-머신 토큰. api 의 governance_service_token 과 일치해야 함(양쪽 미설정=dev 개방).
# 요청 헤더 X-Governance-Token 으로 전송된다.
GOVERNANCE_SERVICE_TOKEN=

# ── LLM 머신 인제스트 (P1.6) ──
# 파이프라인 머지 성공·Linear 웹훅 상태전이를 clickeye-llm KB 로 자동 인제스트한다.
# **명시적 opt-in**: 미설정/false = off (is_enabled 기본-활성 규칙과 달리 값이 있어야 켜짐 → 회귀 0).
# 대상은 FLOWOPS_GOVERNANCE_SERVICE_URL 재사용(POST /api/v1/llm/ingest/pipeline,
# X-Governance-Token 동일). API 쪽 FEATURE_LLM_AUTOINGEST 도 켜져야 실제 인제스트된다.
# team→project 역매핑(project_linear_credentials)이 정확히 1건일 때만 KB 에 기록(오염 방지).
FLOWOPS_LLM_INGEST=false

# ── Temporal 오케스트레이션 (CE-296 P0 토대, CE-297 P1 섀도우) ──
# 마스터 토글: off면 Temporal 레일 전체 미사용 → 기존 파이프라인 무영향(회귀 0).
# pipeline_config.sh is_enabled 는 "미설정=활성" 이므로 기본 off 를 위해 명시적 =false.
# P1 섀도우 트리거(auto_dev_pipeline.sh): 명시적으로 활성(=true)일 때만 ShadowDeliveryWorkflow 를
#   fire-and-forget 로 트리거해 거버넌스 결정을 미러링·대조 로깅한다(머지/커밋/PR 부작용 0, 비블로킹).
FLOWOPS_TEMPORAL=false
# FastAPI 설정(app/config.py Settings.feature_temporal). off면 워커 프로세스 즉시 종료.
FEATURE_TEMPORAL=false
# 워커 연결 대상(로컬 직접 실행 시 localhost:7233, docker compose 내부는 temporal:7233)
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=clickeye-default
