# ClickEye 환경변수 템플릿
# cp .env.example .env 후 값을 채워 사용하세요.
# .env는 .gitignore에 등록되어 있으므로 커밋되지 않습니다.

# ── ClickEye API 서버 ──
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
REDIS_URL=redis://localhost:6379
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=true

# ── ClickEye Web ──
NEXT_PUBLIC_API_URL=http://localhost:8000
AUTH_SECRET=dev-auth-secret-change-in-production
AUTH_URL=http://localhost:3000

# ── ClickEye Agent ──
CLICKEYE_AGENT_ID=your-agent-id
CLICKEYE_AGENT_SECRET=your-agent-secret
CLICKEYE_LICENSE_KEY=your-license-key
CLICKEYE_CLOUD_WS_URL=ws://localhost:8000
CLICKEYE_HEARTBEAT_INTERVAL=30
CLICKEYE_DATA_DIR=/data/clickeye

# ── Flow-Ops 파이프라인 (필수: Linear) ──
LINEAR_API_KEY=lin_api_YOUR_KEY_HERE
LINEAR_TEAM_ID=your-team-uuid
# 멀티팀 사용 시:
# LINEAR_TEAM_ID_DEV=your-dev-team-uuid
# LINEAR_TEAM_ID_DOCS=your-docs-team-uuid

# ── 선택: 외부 AI 코드 리뷰 ──
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── 선택: Telegram 알림 ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 선택: GitHub Token ──
GIT_TOKEN=

# ── 선택: Figma MCP ──
FIGMA_ACCESS_TOKEN=

# ── 선택: Anthropic API ──
ANTHROPIC_API_KEY=

# ── Flow-Ops 모듈 토글 (true/false) ──
FLOWOPS_LINEAR_WATCHER=true
FLOWOPS_LINEAR_REPORT=true
FLOWOPS_LINEAR_CONFIRM=true
FLOWOPS_AUTO_PR=true
FLOWOPS_AUTO_MERGE=true
FLOWOPS_AUTO_COMMIT=true
FLOWOPS_GPT_REVIEW=false
FLOWOPS_RALPH_STOP_HOOK=true
FLOWOPS_TELEGRAM=true
FLOWOPS_TODO_REMINDER=true
# 기획 단계: 메타프롬프트 정제(관측형 사전 정제)가 기본. false면 Gemini 레거시로 폴백.
FLOWOPS_METAPROMPT=true
FLOWOPS_GEMINI_PLAN=false
FLOWOPS_CODEX_REVIEW=true
