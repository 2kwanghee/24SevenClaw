#!/usr/bin/env bash
# Linear Webhook 서버 시작 — {{ project_name }}
# 사용법: bash scripts/start-webhook.sh [--dry-run]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# .env 로드
if [[ -f "$PROJECT_ROOT/.env" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "$PROJECT_ROOT/.env"
    set +a
fi

echo "🔗 Linear Webhook 서버 시작..."
echo "   프로젝트 : {{ project_name }}"
echo "   포트     : ${WEBHOOK_PORT:-9876}"
echo "   터널 URL : ${WEBHOOK_PUBLIC_URL:-미설정 (setup-tunnel.sh 실행 필요)}"
echo ""

if [[ -z "${WEBHOOK_PUBLIC_URL:-}" ]]; then
    echo "⚠️  WEBHOOK_PUBLIC_URL이 설정되지 않았습니다."
    echo "   먼저 bash scripts/setup-tunnel.sh 를 실행하거나"
    echo "   폴링 모드를 사용하세요: python3 scripts/linear_watcher.py"
    echo ""
fi

python3 "$SCRIPT_DIR/webhook_server.py" --port "${WEBHOOK_PORT:-9876}" "$@"
