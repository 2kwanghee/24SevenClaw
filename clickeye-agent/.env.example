# Agent 식별
# CLICKEYE_AGENT_ID: hub 라우팅용 라벨 (쿼리 인증에 함께 전송)
CLICKEYE_AGENT_ID=
# CLICKEYE_AGENT_TOKEN: canonical 크리덴셜 (서버 DB unique 컬럼과 매칭 — 핸드셰이크 필수)
CLICKEYE_AGENT_TOKEN=
# CLICKEYE_AGENT_SECRET: 하위 호환용 (현재 핸드셰이크 미사용)
CLICKEYE_AGENT_SECRET=
CLICKEYE_LICENSE_KEY=

# Cloud 연결
CLICKEYE_CLOUD_WS_URL=wss://api.clickeye.io
CLICKEYE_HEARTBEAT_INTERVAL=30

# 로컬 저장소
CLICKEYE_DATA_DIR=/data/clickeye
