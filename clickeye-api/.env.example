# Database
DATABASE_URL=postgresql+asyncpg://clickeye:devpassword@localhost:5432/clickeye

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET_KEY=change-this-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# App
DEBUG=true

# Anthropic (AI 초안 생성 필수)
ANTHROPIC_API_KEY=sk-ant-...

# ClickEye 클라우드 공개 URL (ZIP .env에 CLICKEYE_API_URL로 베이크됨)
# ⚠️  사용자 PC가 도달 가능한 URL이어야 함. localhost/127.0.0.1은 다른 PC에서 실패함.
# 개발 중 외부 테스트: cloudflared tunnel 또는 ngrok으로 포워딩된 URL 사용.
PUBLIC_API_URL=https://api.your-domain.com

# Feature flags
# ClickEye Modernize (기존 코드 현대화 파이프라인, MVP-2-A). 기본 false — 화이트리스트 베타.
FEATURE_MODERNIZE_ENABLED=false
