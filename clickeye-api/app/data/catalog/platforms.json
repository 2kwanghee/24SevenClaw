[
  {
    "id": "claude-code",
    "name": "Claude Code",
    "description": "Anthropic Claude 기반 코드 에이전트",
    "provider": "anthropic",
    "config_dir": ".claude",
    "agent_file": ".claude/agents/{agent_name}.md",
    "config_files": [
      ".claude/settings.json",
      ".claude/commands/{command_name}.md",
      "CLAUDE.md"
    ],
    "supported_languages": ["python", "typescript", "javascript", "go", "rust"],
    "env_vars": ["ANTHROPIC_API_KEY"],
    "tags": ["ai", "code", "anthropic"]
  },
