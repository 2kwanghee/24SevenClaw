#!/usr/bin/env bash
# {{ project_name }} — 설정 초기화 스크립트
# 사용법: bash remove.sh [옵션]
#   옵션 없음      : 전체 초기화 (프로세스 종료 + webhook 해제 + .env 초기화)
#   --stop-only    : 프로세스 종료만
#   --unregister-webhook : Linear webhook 해제만
#   --reset-env    : .env 초기화만
#   --clean-logs   : log/ 폴더 삭제 (확인 후)
set -euo pipefail

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"
LOG_DIR="$SCRIPT_DIR/log"

# ── 헬퍼 ───────────────────────────────────────────────────────────────────────

get_env_val() {
  grep -E "^${1}=" "$ENV_FILE" 2>/dev/null | cut -d= -f2- | tr -d '"' || true
}

# ── 프로세스 종료 ───────────────────────────────────────────────────────────────

stop_processes() {
  echo -e "${BOLD}[1/4] 실행 중인 프로세스 종료${NC}"
  local stopped=0

  for proc in "webhook_server.py" "linear_watcher.py"; do
    local pids
    pids=$(pgrep -f "$proc" 2>/dev/null || true)
    if [ -n "$pids" ]; then
      echo "$pids" | xargs kill -TERM 2>/dev/null || true
      sleep 1
      echo -e "  ${GREEN}✅ $proc 종료됨${NC}"
      stopped=$((stopped + 1))
    fi
  done

  if [ "$stopped" -eq 0 ]; then
    echo -e "  ${YELLOW}ℹ  실행 중인 프로세스 없음${NC}"
  fi
}

# ── Linear Webhook 해제 ─────────────────────────────────────────────────────────

unregister_webhook() {
  echo -e "${BOLD}[2/4] Linear Webhook 해제${NC}"

  local api_key
  api_key=$(get_env_val "LINEAR_API_KEY")

  if [ -z "$api_key" ]; then
    echo -e "  ${YELLOW}ℹ  LINEAR_API_KEY 미설정 — 건너뜀${NC}"
    return
  fi

  # 등록된 webhook 목록 조회 후 ClickEye 레이블 webhook 삭제
  python3 - <<PYEOF
import urllib.request, urllib.error, json, sys

api_key = "$api_key"
headers = {"Authorization": api_key, "Content-Type": "application/json"}

query = '{"query": "{ webhooks { nodes { id label } } }"}'
req = urllib.request.Request("https://api.linear.app/graphql", data=query.encode(), headers=headers)
try:
    with urllib.request.urlopen(req, timeout=10) as r:
        data = json.loads(r.read())
except Exception as e:
    print(f"  ⚠️  Webhook 조회 실패: {e}")
    sys.exit(0)

webhooks = data.get("data", {}).get("webhooks", {}).get("nodes", [])
target = [w for w in webhooks if w.get("label") == "ClickEye"]

if not target:
    print("  ℹ️  등록된 ClickEye Webhook 없음")
    sys.exit(0)

for wh in target:
    mutation = json.dumps({"query": f'mutation {{ webhookDelete(id: "{wh["id"]}") {{ success }} }}'})
    req2 = urllib.request.Request("https://api.linear.app/graphql", data=mutation.encode(), headers=headers)
    try:
        with urllib.request.urlopen(req2, timeout=10) as r2:
            res = json.loads(r2.read())
        if res.get("data", {}).get("webhookDelete", {}).get("success"):
            print(f"  ✅ Webhook 해제 완료 (id: {wh['id']})")
        else:
            print(f"  ⚠️  Webhook 해제 실패 (id: {wh['id']})")
    except Exception as e:
        print(f"  ⚠️  Webhook 삭제 오류: {e}")
PYEOF
}

# ── .env 초기화 ─────────────────────────────────────────────────────────────────

reset_env() {
  echo -e "${BOLD}[3/4] .env 초기화${NC}"

  if [ ! -f "$ENV_FILE" ]; then
    echo -e "  ${YELLOW}ℹ  .env 파일 없음 — 건너뜀${NC}"
    return
  fi

  # 키=값 → 키= 형태로 초기화 (주석 라인은 유지)
  python3 - <<PYEOF
with open("$ENV_FILE", "r") as f:
    lines = f.readlines()

result = []
for line in lines:
    stripped = line.strip()
    if stripped.startswith("#") or "=" not in stripped:
        result.append(line)
    else:
        key = stripped.split("=", 1)[0]
        result.append(f"{key}=\n")

with open("$ENV_FILE", "w") as f:
    f.writelines(result)
print("  ✅ .env 초기화 완료")
PYEOF
}

# ── 로그 정리 ────────────────────────────────────────────────────────────────────

clean_logs() {
  echo -e "${BOLD}[4/4] 로그 파일 정리${NC}"

  if [ ! -d "$LOG_DIR" ] || [ -z "$(ls -A "$LOG_DIR" 2>/dev/null)" ]; then
    echo -e "  ${YELLOW}ℹ  로그 파일 없음 — 건너뜀${NC}"
    return
  fi

  echo -e "  ${YELLOW}log/ 폴더의 로그를 삭제할까요? (y/N):${NC} "
  read -r answer
  if [[ "$answer" =~ ^[Yy]$ ]]; then
    rm -f "$LOG_DIR"/*.log
    echo -e "  ${GREEN}✅ 로그 파일 삭제 완료${NC}"
  else
    echo -e "  ${YELLOW}ℹ  로그 보존됨${NC}"
  fi
}

# ── 메인 ─────────────────────────────────────────────────────────────────────────

MODE="${1:-all}"

echo ""
echo -e "${BOLD}🗑️  {{ project_name }} — 설정 초기화${NC}"
echo "============================================"

case "$MODE" in
  --stop-only)
    stop_processes
    ;;
  --unregister-webhook)
    unregister_webhook
    ;;
  --reset-env)
    reset_env
    ;;
  --clean-logs)
    clean_logs
    ;;
  all)
    stop_processes
    echo ""
    unregister_webhook
    echo ""
    reset_env
    echo ""
    clean_logs
    echo ""
    echo -e "${BOLD}${GREEN}"
    echo "╔══════════════════════════════════════════╗"
    echo "║  🗑️  설정 초기화 완료                     ║"
    echo "╚══════════════════════════════════════════╝"
    echo -e "${NC}"
    echo "프로젝트: {{ project_name }}"
    echo ""
    echo "다시 설정하려면: /clickeyestart"
    ;;
  *)
    echo -e "${RED}알 수 없는 옵션: $MODE${NC}"
    echo "사용법: bash remove.sh [--stop-only|--unregister-webhook|--reset-env|--clean-logs]"
    exit 1
    ;;
esac
