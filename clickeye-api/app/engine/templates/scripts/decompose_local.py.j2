#!/usr/bin/env python3
"""위저드 요구사항 → 서브태스크 분해기.

입력: requirements.json  ({"requirements_text": "...", "project_name": "..."})
출력: subtasks.json      ([{role, title, description, _method}, ...])

분해 우선순위:
  1. claude CLI 헤드리스 (구독 사용)
  2. 서버측 Claude AI (CLICKEYE_API_URL/setup/decompose-server)
  3. 단일 wrap (manual)
"""
from __future__ import annotations

import json
import os
import re
import subprocess
import sys
import urllib.error
import urllib.request
from typing import Any

DECOMPOSE_PROMPT = """\
당신은 소프트웨어 개발 태스크를 역할별로 분해하는 전문가입니다.
아래 요구사항을 읽고, 개발에 필요한 서브태스크를 JSON 배열로만 반환하세요.
다른 텍스트 없이 JSON 배열만 출력하세요.

각 서브태스크는 다음 형식의 JSON 객체를 따릅니다:
{
  "role": "<backend|frontend|qa|architect|designer|devops|pm|fullstack>",
  "title": "<50자 이내, 명령형 동사로 시작 (예: '~를 구현한다', '~를 설정한다')>",
  "description": "<상세 작업 설명. 왜 필요한지 + 어떻게 시작하는지 2~5문장. 마크다운 허용>",
  "phase": "<mvp|v2|future>",
  "priority": "<high|medium|low>",
  "estimate_hours": <정수, 1~40>,
  "depends_on": ["<선행 서브태스크 title 그대로 인용>"],
  "acceptance_criteria": ["<완료 기준 한 줄씩>"]
}

규칙:
- phase: mvp=핵심 사용자 가치, v2=보강, future=nice-to-have
- depends_on: 선행 서브태스크의 title을 정확히 인용 (오타 주의)
- acceptance_criteria: 테스트 가능한 완료 조건 2~5개
- 서브태스크는 최소 2개, 최대 10개
- architect 태스크는 항상 mvp에 포함하고 다른 태스크의 선행 조건으로 설정

요구사항:
{requirements}
"""


def _server_decompose(
    requirements_text: str,
    api_url: str,
    project_id: str,
    setup_token: str,
) -> list[dict[str, Any]] | None:
    """서버측 Claude AI로 분해 요청 (claude CLI 없는 환경 폴백)."""
    url = f"{api_url.rstrip('/')}/api/v1/projects/{project_id}/setup/decompose-server"
    payload = json.dumps({"requirements_text": requirements_text}).encode("utf-8")
    req = urllib.request.Request(
        url,
        data=payload,
        headers={
            "Authorization": f"Bearer {setup_token}",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=120) as resp:
            body = json.loads(resp.read().decode("utf-8"))
            subtasks = body.get("subtasks", [])
            _VALID_METHODS = {"claude-cli", "rule-based", "manual", "claude-server"}
            raw_method = body.get("method", "claude-server")
            method = raw_method if raw_method in _VALID_METHODS else "manual"
            result = []
            for item in subtasks:
                if not isinstance(item, dict):
                    continue
                result.append({
                    "role": str(item.get("role", "architect"))[:50],
                    "title": str(item.get("title", ""))[:500],
                    "description": str(item.get("description", ""))[:2000],
                    "_method": method,
                })
            return result if result else None
    except (urllib.error.URLError, urllib.error.HTTPError, json.JSONDecodeError, KeyError):
        return None


def _claude_cli(requirements_text: str, project_name: str) -> list[dict[str, Any]] | None:
    prompt = DECOMPOSE_PROMPT.replace("{requirements}", requirements_text[:3000])
    try:
        result = subprocess.run(
            ["claude", "-p", prompt, "--output-format", "json"],
            capture_output=True, text=True, timeout=60
        )
        if result.returncode != 0:
            return None
        # JSON 배열 추출 (claude가 감싸는 JSON wrapper에서 꺼내기)
        stdout = result.stdout.strip()
        # claude --output-format json: {"type":"result","subtype":"success","result":"..."}
        try:
            wrapper = json.loads(stdout)
            if isinstance(wrapper, dict) and "result" in wrapper:
                inner = wrapper["result"]
                if isinstance(inner, str):
                    inner = inner.strip()
                    # 코드블록 제거
                    inner = re.sub(r"^```[a-z]*\n?", "", inner)
                    inner = re.sub(r"\n?```$", "", inner)
                    subtasks = json.loads(inner)
                elif isinstance(inner, list):
                    subtasks = inner
                else:
                    return None
            elif isinstance(wrapper, list):
                subtasks = wrapper
            else:
                return None
        except (json.JSONDecodeError, KeyError):
            return None

        if not isinstance(subtasks, list) or not subtasks:
            return None
        result_list = []
        for item in subtasks[:10]:
            if not isinstance(item, dict):
                continue
            desc_base = str(item.get("description", ""))
            depends_on = item.get("depends_on") or []
            ac_list = item.get("acceptance_criteria") or []
            phase = str(item.get("phase", "mvp"))
            priority = str(item.get("priority", "medium"))
            estimate = item.get("estimate_hours")

            md_parts = [desc_base]
            md_parts.append(
                f"\n**Phase**: {phase} | **Priority**: {priority}"
                + (f" | **Estimate**: {estimate}h" if estimate is not None else "")
            )
            if depends_on:
                md_parts.append("\n**Depends on**: " + ", ".join(str(d) for d in depends_on))
            if ac_list:
                md_parts.append("\n**Acceptance Criteria**:\n" + "\n".join(f"- {c}" for c in ac_list))
            md_desc = "\n".join(md_parts)

            result_list.append({
                "role": str(item.get("role", "architect"))[:50],
                "title": str(item.get("title", ""))[:500],
                "description": md_desc[:2000],
                "_phase": phase,
                "_priority": priority,
                "_estimate_hours": estimate,
                "_depends_on": list(depends_on),
                "_acceptance_criteria": list(ac_list),
                "_method": "claude-cli",
            })
        return result_list if result_list else None
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
        return None


def main(reqs_path: str, out_path: str) -> None:
    with open(reqs_path, encoding="utf-8") as f:
        data = json.load(f)
    requirements_text: str = data.get("requirements_text") or ""
    project_name: str = data.get("project_name") or "프로젝트"

    if not requirements_text.strip():
        subtasks: list[dict[str, Any]] = [{
            "role": "architect",
            "title": f"[architect] {project_name} 초기 설계",
            "description": "위저드에 요구사항이 입력되지 않았습니다. AI Team에서 서브태스크를 직접 추가하세요.",
            "_method": "manual",
        }]
    else:
        # 1순위: claude CLI
        print("[decompose] claude CLI 시도 중...", file=sys.stderr)
        subtasks = _claude_cli(requirements_text, project_name) or []

        # 2순위: 서버측 Claude AI (claude CLI 미설치 환경)
        if not subtasks:
            api_url = os.environ.get("CLICKEYE_API_URL", "")
            project_id = os.environ.get("CLICKEYE_PROJECT_ID", "")
            setup_token = os.environ.get("CLICKEYE_SETUP_TOKEN", "")
            if api_url and project_id and setup_token:
                print("[decompose] claude CLI 실패 — 서버측 AI 분해로 폴백합니다.", file=sys.stderr)
                subtasks = _server_decompose(requirements_text, api_url, project_id, setup_token) or []
            else:
                print("[decompose] claude CLI 실패 — 환경 변수 누락으로 서버 폴백 불가.", file=sys.stderr)

        # 3순위: manual (단일 architect 태스크)
        if not subtasks:
            print("[decompose] 서버 분해 실패 — 단일 서브태스크로 폴백합니다.", file=sys.stderr)
            subtasks = [{
                "role": "architect",
                "title": f"[architect] {project_name} 초기 설계",
                "description": requirements_text[:500],
                "_method": "manual",
            }]

    with open(out_path, "w", encoding="utf-8") as f:
        json.dump(subtasks, f, ensure_ascii=False, indent=2)
    print(f"[decompose] {len(subtasks)}개 서브태스크 생성 완료.", file=sys.stderr)


if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: decompose_local.py <requirements.json> <subtasks.json>", file=sys.stderr)
        sys.exit(1)
    main(sys.argv[1], sys.argv[2])
