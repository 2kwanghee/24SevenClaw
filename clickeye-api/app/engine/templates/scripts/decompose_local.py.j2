#!/usr/bin/env python3
"""위저드 요구사항 → 서브태스크 분해기.

입력: requirements.json  ({"requirements_text": "...", "project_name": "..."})
출력: subtasks.json      ([{role, title, description, _method}, ...])

분해 우선순위:
  1. 로컬 claude CLI (구독 / ANTHROPIC_API_KEY 모두 지원)
  2. 단일 wrap (manual) — claude 미설치·미인증 시 폴백
"""
from __future__ import annotations

import glob
import json
import os
import re
import shutil
import subprocess
import sys
from typing import Any

DECOMPOSE_PROMPT = """\
당신은 소프트웨어 프로젝트 오케스트레이터입니다.
Claude Plan 모드처럼 아래 요구사항을 정밀하게 분석하여 AI 팀이 실행 가능한 서브태스크로 분해하세요.

분석 절차:
1. 핵심 도메인과 기술 스택을 식별하세요.
2. 구현 단계(mvp→v2→future)로 분해하세요.
3. 서브태스크 간 의존성을 매핑하세요.
4. 각 서브태스크에 측정 가능한 완료 기준(AC)을 2~5개 작성하세요.

규칙:
- 사용자 입력을 그대로 옮기지 마세요. 실행 가능한 단위로 재구성하세요.
- architect 태스크는 항상 포함하고 다른 태스크의 선행 조건으로 설정하세요.
- 서브태스크는 최소 3개, 최대 10개.
- 제목: 50자 이내, 명령형 동사로 시작 (예: '~를 구현한다', '~를 설계한다').
- 설명: 무엇을, 왜, 어떻게 — 3~5문장 한국어.
- 모든 텍스트를 한국어로 작성하세요.

IMPORTANT: 유효한 JSON 배열만 반환하세요 — 마크다운, 코드블록, 추가 텍스트 없이.

반환 형식 (JSON 배열):
[
  {
    "role": "<architect|frontend|backend|qa|security|devops>",
    "title": "<50자 이내, 명령형 동사로 시작>",
    "description": "<무엇을, 왜, 어떻게 — 3~5문장>",
    "phase": "<mvp|v2|future>",
    "priority": "<high|medium|low>",
    "estimate_hours": <정수 1~40>,
    "depends_on": ["<선행 서브태스크 title 정확히 인용>"],
    "acceptance_criteria": ["<측정 가능한 완료 조건>", "..."]
  }
]

요구사항:
{requirements}
"""


def _find_claude() -> str | None:
    """로컬 claude CLI 실행 파일의 절대 경로를 반환한다.

    shutil.which 우선, 이후 npm global 일반 경로를 순서대로 탐색.
    """
    found = shutil.which("claude")
    if found:
        return found

    home = os.path.expanduser("~")
    candidates = [
        "/usr/local/bin/claude",
        "/usr/bin/claude",
        f"{home}/.npm-global/bin/claude",
        f"{home}/.npm/bin/claude",
        f"{home}/.local/bin/claude",
        f"{home}/bin/claude",
        # nvm 경로 (와일드카드)
        f"{home}/.nvm/versions/node/*/bin/claude",
        # volta
        f"{home}/.volta/bin/claude",
    ]
    for pattern in candidates:
        for path in glob.glob(pattern):
            if os.path.isfile(path) and os.access(path, os.X_OK):
                return path
    return None


def _claude_cli(requirements_text: str, project_name: str) -> list[dict[str, Any]] | None:  # noqa: ARG001
    """로컬 claude CLI로 요구사항을 분해한다.

    -p 플래그로 프롬프트를 인자로 전달 (stdin 방식보다 호환성 높음).
    ANTHROPIC_API_KEY 또는 claude.ai 구독 세션 모두 지원.
    """
    claude_bin = _find_claude()
    if not claude_bin:
        print("[decompose] claude CLI를 찾을 수 없습니다. PATH를 확인하세요.", file=sys.stderr)
        return None

    prompt = DECOMPOSE_PROMPT.replace("{requirements}", requirements_text[:4000])
    print(f"[decompose] claude CLI 실행: {claude_bin}", file=sys.stderr)

    # 1차 시도: -p 인자 방식 + JSON 출력 포맷
    subtasks = _run_claude(claude_bin, prompt, use_json_format=True)
    if subtasks is None:
        # 2차 시도: -p 인자 방식, plain text 출력 (구버전 CLI 호환)
        print("[decompose] JSON 포맷 실패 — plain text 모드 재시도.", file=sys.stderr)
        subtasks = _run_claude(claude_bin, prompt, use_json_format=False)
    return subtasks


def _run_claude(claude_bin: str, prompt: str, *, use_json_format: bool) -> list[dict[str, Any]] | None:
    cmd = [claude_bin, "-p", prompt]
    if use_json_format:
        cmd += ["--output-format", "json"]

    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=120,
            env={**os.environ, "TERM": "dumb"},  # 터미널 감지 오류 방지
        )
    except subprocess.TimeoutExpired:
        print("[decompose] claude CLI 타임아웃 (120s).", file=sys.stderr)
        return None
    except (FileNotFoundError, OSError) as e:
        print(f"[decompose] claude CLI 실행 실패: {e}", file=sys.stderr)
        return None

    if result.returncode != 0:
        err_preview = (result.stderr or result.stdout or "")[:400].strip()
        print(f"[decompose] claude CLI 오류 (rc={result.returncode}): {err_preview}", file=sys.stderr)
        return None

    stdout = result.stdout.strip()
    if not stdout:
        stderr_preview = (result.stderr or "")[:200].strip()
        print(f"[decompose] claude CLI 출력 없음. stderr: {stderr_preview}", file=sys.stderr)
        return None

    # JSON 포맷: {"type":"result","subtype":"success","result":"[...]"}
    # Plain text: 직접 JSON 배열 또는 마크다운 펜스 내 JSON
    try:
        parsed = json.loads(stdout)
    except json.JSONDecodeError:
        parsed = None

    if parsed is None:
        # plain text — 마크다운 펜스 제거 후 재시도
        cleaned = re.sub(r"^```[a-z]*\n?", "", stdout.strip())
        cleaned = re.sub(r"\n?```$", "", cleaned)
        try:
            parsed = json.loads(cleaned)
        except json.JSONDecodeError as e:
            print(f"[decompose] JSON 파싱 오류: {e} — 응답: {stdout[:200]}", file=sys.stderr)
            return None

    if isinstance(parsed, dict) and "result" in parsed:
        inner = parsed["result"]
        if isinstance(inner, str):
            inner = inner.strip()
            inner = re.sub(r"^```[a-z]*\n?", "", inner)
            inner = re.sub(r"\n?```$", "", inner)
            try:
                subtasks = json.loads(inner)
            except json.JSONDecodeError as e:
                print(f"[decompose] result 필드 파싱 오류: {e} — 내용: {inner[:200]}", file=sys.stderr)
                return None
        elif isinstance(inner, list):
            subtasks = inner
        else:
            print(f"[decompose] claude 응답 'result' 형식 불명확: {type(inner)}", file=sys.stderr)
            return None
    elif isinstance(parsed, list):
        subtasks = parsed
    else:
        print(f"[decompose] claude 응답 파싱 실패 (type={type(parsed).__name__}): {stdout[:200]}", file=sys.stderr)
        return None

    if not isinstance(subtasks, list) or not subtasks:
        return None

    if not isinstance(subtasks, list) or not subtasks:
        return None

    result_list = []
    for item in subtasks[:10]:
        if not isinstance(item, dict):
            continue
        desc_base = str(item.get("description", ""))
        depends_on = item.get("depends_on") or []
        ac_list = item.get("acceptance_criteria") or []
        phase = str(item.get("phase", "mvp"))
        priority = str(item.get("priority", "medium"))
        estimate = item.get("estimate_hours")

        md_parts = [desc_base]
        md_parts.append(
            f"\n**Phase**: {phase} | **Priority**: {priority}"
            + (f" | **Estimate**: {estimate}h" if estimate is not None else "")
        )
        if depends_on:
            md_parts.append("\n**Depends on**: " + ", ".join(str(d) for d in depends_on))
        if ac_list:
            md_parts.append("\n**Acceptance Criteria**:\n" + "\n".join(f"- {c}" for c in ac_list))

        result_list.append({
            "role": str(item.get("role", "architect"))[:50],
            "title": str(item.get("title", ""))[:500],
            "description": "\n".join(md_parts)[:2000],
            "_phase": phase,
            "_priority": priority,
            "_estimate_hours": estimate,
            "_depends_on": list(depends_on),
            "_acceptance_criteria": list(ac_list),
            "_method": "claude-cli",
        })
    return result_list if result_list else None


def main(reqs_path: str, out_path: str) -> None:
    with open(reqs_path, encoding="utf-8") as f:
        data = json.load(f)
    requirements_text: str = data.get("requirements_text") or ""
    project_name: str = data.get("project_name") or "프로젝트"

    if not requirements_text.strip():
        subtasks: list[dict[str, Any]] = [{
            "role": "architect",
            "title": f"[architect] {project_name} 초기 설계",
            "description": "위저드에 요구사항이 입력되지 않았습니다. AI Team에서 서브태스크를 직접 추가하세요.",
            "_method": "manual",
        }]
    else:
        print("[decompose] 로컬 claude CLI로 요구사항 분해 시도 중...", file=sys.stderr)
        subtasks = _claude_cli(requirements_text, project_name) or []

        if not subtasks:
            print(
                "[decompose] claude CLI 분해 실패 — AI Team에서 서브태스크를 직접 추가하세요.\n"
                "  • claude 미설치: npm install -g @anthropic-ai/claude-code\n"
                "  • 미인증: claude (로그인 후 재시도)",
                file=sys.stderr,
            )
            subtasks = [{
                "role": "architect",
                "title": f"[architect] {project_name} 초기 설계",
                "description": (
                    "로컬 claude CLI 분해에 실패했습니다. "
                    "AI Team에서 서브태스크를 직접 추가하거나, "
                    "claude CLI 설치·인증 후 bootstrap을 재실행하세요.\n\n"
                    f"원본 요구사항:\n{requirements_text[:800]}"
                ),
                "_method": "manual",
            }]

    with open(out_path, "w", encoding="utf-8") as f:
        json.dump(subtasks, f, ensure_ascii=False, indent=2)
    print(f"[decompose] {len(subtasks)}개 서브태스크 생성 완료.", file=sys.stderr)


if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: decompose_local.py <requirements.json> <subtasks.json>", file=sys.stderr)
        sys.exit(1)
    main(sys.argv[1], sys.argv[2])
