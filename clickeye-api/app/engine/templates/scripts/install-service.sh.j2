#!/usr/bin/env bash
# {{ project_name }} — systemd 사용자 서비스 등록
# 사용법: bash scripts/install-service.sh
# 효과  : 터미널 종료 후에도 파이프라인 자동 유지 + 크래시 시 자동 재시작
set -euo pipefail

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SYSTEMD_USER_DIR="$HOME/.config/systemd/user"
PYTHON3="$(command -v python3 || echo '/usr/bin/python3')"
# 로그인 셸 PATH 스냅샷 — nvm/volta/npm-global 경로 포함 (systemd 환경에서 PATH 누락 대비)
USER_PATH="$(bash -lc 'echo $PATH' 2>/dev/null || echo "/usr/local/bin:/usr/bin:/bin")"
USER_HOME="${HOME}"
RUN_USER="${USER}"

echo ""
echo -e "${BOLD}⚙️  ClickEye 서비스 등록${NC}"
echo "============================================"

# ── systemd --user 사용 가능 여부 확인 ────────────────────────────────────────
if ! systemctl --user status > /dev/null 2>&1 && \
   ! systemctl --user list-units > /dev/null 2>&1; then
  echo -e "${RED}❌ systemd --user를 사용할 수 없습니다.${NC}"
  echo "   /etc/wsl.conf 에 아래 내용이 있는지 확인하세요:"
  echo "   [boot]"
  echo "   systemd=true"
  exit 1
fi

mkdir -p "$SYSTEMD_USER_DIR" "$PROJECT_ROOT/logs"

# ── [1/{% if has_linear %}4{% else %}2{% endif %}] clickeye-watcher 서비스 ────────────────────────────────────────────
echo -e "${CYAN}[1/{% if has_linear %}4{% else %}2{% endif %}]${NC} clickeye-watcher 서비스 파일 생성..."
cat > "$SYSTEMD_USER_DIR/clickeye-watcher.service" << UNIT
[Unit]
Description=ClickEye Linear Watcher ({{ project_name }})
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=${PROJECT_ROOT}
Environment="HOME=${USER_HOME}"
Environment="USER=${RUN_USER}"
Environment="PATH=${USER_PATH}"
Environment="LANG=C.UTF-8"
ExecStart=${PYTHON3} ${PROJECT_ROOT}/scripts/linear_watcher.py
Restart=always
RestartSec=10
StandardOutput=append:${PROJECT_ROOT}/logs/watcher.log
StandardError=append:${PROJECT_ROOT}/logs/watcher.log
EnvironmentFile=-${PROJECT_ROOT}/.env

[Install]
WantedBy=default.target
UNIT
echo -e "   ${GREEN}✅ clickeye-watcher.service${NC}"

{% if has_linear %}
# ── [2/4] clickeye-webhook 서비스 ────────────────────────────────────────────
echo -e "${CYAN}[2/4]${NC} clickeye-webhook 서비스 파일 생성..."
cat > "$SYSTEMD_USER_DIR/clickeye-webhook.service" << UNIT
[Unit]
Description=ClickEye Webhook Server ({{ project_name }})
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=${PROJECT_ROOT}
Environment="HOME=${USER_HOME}"
Environment="USER=${RUN_USER}"
Environment="PATH=${USER_PATH}"
Environment="LANG=C.UTF-8"
ExecStart=${PYTHON3} ${PROJECT_ROOT}/scripts/webhook_server.py
Restart=always
RestartSec=10
StandardOutput=append:${PROJECT_ROOT}/logs/webhook.log
StandardError=append:${PROJECT_ROOT}/logs/webhook.log
EnvironmentFile=-${PROJECT_ROOT}/.env

[Install]
WantedBy=default.target
UNIT
echo -e "   ${GREEN}✅ clickeye-webhook.service${NC}"

# ── [3/4] clickeye-tunnel 서비스 ─────────────────────────────────────────────
echo -e "${CYAN}[3/4]${NC} clickeye-tunnel 서비스 파일 생성..."
cat > "$SYSTEMD_USER_DIR/clickeye-tunnel.service" << UNIT
[Unit]
Description=ClickEye Cloudflare Tunnel ({{ project_name }})
After=network-online.target clickeye-webhook.service
Wants=network-online.target
Requires=clickeye-webhook.service

[Service]
Type=simple
WorkingDirectory=${PROJECT_ROOT}
Environment="HOME=${USER_HOME}"
Environment="USER=${RUN_USER}"
Environment="PATH=${USER_PATH}"
Environment="LANG=C.UTF-8"
ExecStart=/usr/bin/env bash ${PROJECT_ROOT}/scripts/run-tunnel.sh
Restart=always
RestartSec=10
StandardOutput=append:${PROJECT_ROOT}/logs/tunnel.log
StandardError=append:${PROJECT_ROOT}/logs/tunnel.log
EnvironmentFile=-${PROJECT_ROOT}/.env

[Install]
WantedBy=default.target
UNIT
echo -e "   ${GREEN}✅ clickeye-tunnel.service${NC}"

{% endif %}
# ── [{% if has_linear %}4{% else %}2{% endif %}/{% if has_linear %}4{% else %}2{% endif %}] 서비스 활성화 및 시작 ─────────────────────────────────────────────
echo -e "${CYAN}[{% if has_linear %}4{% else %}2{% endif %}/{% if has_linear %}4{% else %}2{% endif %}]${NC} 서비스 활성화..."
systemctl --user daemon-reload

systemctl --user enable  clickeye-watcher 2>/dev/null || true
systemctl --user restart clickeye-watcher
echo -e "   ${GREEN}✅ clickeye-watcher 시작됨${NC}"

{% if has_linear %}
systemctl --user enable  clickeye-webhook 2>/dev/null || true
systemctl --user restart clickeye-webhook
echo -e "   ${GREEN}✅ clickeye-webhook 시작됨${NC}"

systemctl --user enable  clickeye-tunnel 2>/dev/null || true
systemctl --user restart clickeye-tunnel
echo -e "   ${GREEN}✅ clickeye-tunnel 시작됨${NC}"

{% endif %}
# ── linger 활성화 — WSL2 재시작 후에도 서비스 자동 복구 ─────────────────────
_linger_ok=false
if loginctl enable-linger "$USER" 2>/dev/null; then
  _linger_ok=true
elif sudo loginctl enable-linger "$USER" 2>/dev/null; then
  _linger_ok=true
fi

# linger 실제 적용 여부 검증
if loginctl show-user "$USER" 2>/dev/null | grep -q "Linger=yes"; then
  _linger_ok=true
fi

if [[ "$_linger_ok" == "true" ]]; then
  echo -e "   ${GREEN}✅ linger 활성화 — WSL2 재시작 후에도 서비스 자동 복구${NC}"
else
  echo -e "   ${RED}❌ linger 활성화 실패 — WSL2 재시작 시 서비스가 자동 복구되지 않습니다.${NC}"
  echo -e "   ${YELLOW}   WSL 터미널에서 아래 명령을 실행하세요:${NC}"
  echo "      sudo loginctl enable-linger $USER"
  echo "      bash scripts/install-service.sh  # 재실행"
fi

# ── WSL2 keepalive 서비스 — 유휴 상태에서 WSL이 종료되는 것을 방지 ────────────
cat > "$SYSTEMD_USER_DIR/clickeye-keepalive.service" << UNIT
[Unit]
Description=ClickEye WSL2 Keepalive
After=default.target

[Service]
Type=simple
ExecStart=/usr/bin/env bash -c 'while true; do sleep 60; done'
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
UNIT

systemctl --user daemon-reload
systemctl --user enable  clickeye-keepalive 2>/dev/null || true
systemctl --user restart clickeye-keepalive 2>/dev/null || true
echo -e "   ${GREEN}✅ keepalive 서비스 등록 — WSL2 유휴 종료 방지${NC}"

# ── 완료 ─────────────────────────────────────────────────────────────────────
echo ""
echo -e "╔═══════════════════════════════════════════╗"
echo -e "║  ${GREEN}✅ 서비스 등록 완료${NC}                      ║"
echo -e "╚═══════════════════════════════════════════╝"
echo ""
echo -e "  터미널을 닫아도 파이프라인이 계속 실행됩니다."
echo ""
echo -e "  상태 확인  : ${BOLD}systemctl --user status clickeye-watcher${NC}"
echo -e "  linger 확인: ${BOLD}loginctl show-user $USER | grep Linger${NC}"
echo -e "  로그 확인  : ${BOLD}tail -f logs/watcher.log${NC}"
echo -e "  서비스 중지: ${BOLD}systemctl --user stop clickeye-watcher clickeye-keepalive${NC}"
echo -e "  서비스 제거: ${BOLD}bash scripts/uninstall-service.sh${NC}"
echo ""
echo -e "  ${CYAN}💡 Windows 재시작 후 자동 기동 설정 (선택사항)${NC}"
echo -e "  Windows PowerShell(관리자)에서 아래 명령 실행:"
echo ""
echo -e "  ${BOLD}powershell -ExecutionPolicy Bypass -File \"\$(wslpath -w ${PROJECT_ROOT}/scripts/setup-autostart.ps1)\"${NC}"
echo ""
