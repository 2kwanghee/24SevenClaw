#!/usr/bin/env bash
# refresh-env.sh — 갱신된 .env 파일을 로컬 환경에 적용한다.
# 사용법:
#   1. ClickEye 웹에서 최신 .env 파일을 다운로드한다
#   2. 이 파일을 프로젝트 루트(.env)에 덮어쓴다: cp ~/Downloads/.env ./.env
#   3. 이 스크립트를 실행한다: bash scripts/refresh-env.sh
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RESET='\033[0m'

# ── 1. .env 존재 확인 ──────────────────────────────────────────────────────
ENV_FILE="$(cd "$(dirname "$0")/.." && pwd)/.env"

if [[ ! -f "$ENV_FILE" ]]; then
  echo -e "${RED}✗ .env 파일을 찾을 수 없습니다: $ENV_FILE${RESET}"
  echo "  ClickEye 웹에서 .env 파일을 다운로드한 뒤 프로젝트 루트에 덮어쓰세요."
  exit 1
fi

echo -e "${GREEN}✓ .env 파일 확인: $ENV_FILE${RESET}"

# ── 2. 필수 키 검증 ────────────────────────────────────────────────────────
REQUIRED_KEYS=(ANTHROPIC_API_KEY)
MISSING=()

for key in "${REQUIRED_KEYS[@]}"; do
  val=$(grep -E "^${key}=" "$ENV_FILE" | cut -d= -f2- | xargs 2>/dev/null || true)
  if [[ -z "$val" ]]; then
    MISSING+=("$key")
  else
    prefix="${val:0:12}..."
    echo "  $key = $prefix (확인됨)"
  fi
done

if [[ {% raw %}${#MISSING[@]}{% endraw %} -gt 0 ]]; then
  echo -e "${YELLOW}⚠ 다음 필수 키가 비어 있습니다: ${MISSING[*]}${RESET}"
  echo "  ClickEye → 설정 → Anthropic API 키 에서 키를 등록 후 .env를 재다운로드하세요."
fi

# ── 3. clickeye-tunnel systemd 서비스 재시작 (있을 때만) ──────────────────
if systemctl --user list-unit-files clickeye-tunnel.service &>/dev/null 2>&1; then
  echo ""
  echo "clickeye-tunnel 서비스를 재시작합니다..."
  if systemctl --user restart clickeye-tunnel.service; then
    echo -e "${GREEN}✓ clickeye-tunnel 재시작 완료${RESET}"
  else
    echo -e "${YELLOW}⚠ clickeye-tunnel 재시작 실패 — 수동으로 확인하세요:${RESET}"
    echo "  systemctl --user status clickeye-tunnel.service"
  fi
else
  echo ""
  echo "  (clickeye-tunnel 서비스 미설치 — 스킵)"
fi

# ── 4. 완료 안내 ──────────────────────────────────────────────────────────
echo ""
echo -e "${GREEN}✓ .env 갱신 완료${RESET}"
echo "  열려있는 Claude Code 세션이 있다면 종료 후 재시작하세요:"
echo "    1) 세션 종료: Ctrl+C (또는 /exit)"
echo "    2) 재시작: claude (프로젝트 루트에서)"
