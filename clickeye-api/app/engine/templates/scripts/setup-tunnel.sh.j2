#!/usr/bin/env bash
# Cloudflare Tunnel / ngrok 자동 설치 및 기동 — {{ project_name }}
# 사용법:
#   bash scripts/setup-tunnel.sh            # 포그라운드 (터미널 점유)
#   bash scripts/setup-tunnel.sh --detach   # 백그라운드 기동 (start.sh에서 호출)
#
# TUNNEL_PROVIDER 환경변수로 방식 선택:
#   cloudflare (기본) — 무료, 일시적 URL
#   ngrok              — 유료 고정 URL / 무료 임시 URL
#   polling            — 터널 없이 30초 폴링 사용
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
ENV_FILE="$PROJECT_ROOT/.env"
WEBHOOK_PORT="${WEBHOOK_PORT:-9876}"
DETACH_MODE=0
[[ "${1:-}" == "--detach" ]] && DETACH_MODE=1

# .env 로드
if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1091
    source "$ENV_FILE"
    set +a
fi

TUNNEL_PROVIDER="${TUNNEL_PROVIDER:-cloudflare}"
mkdir -p "$PROJECT_ROOT/.run"

_update_env() {
    local key="$1"
    local value="$2"
    if grep -q "^${key}=" "$ENV_FILE" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$ENV_FILE"
    else
        echo "${key}=${value}" >> "$ENV_FILE"
    fi
}

echo "🌐 터널 설정 시작 ({{ project_name }})"
echo "   방식: $TUNNEL_PROVIDER"
echo ""

# ── polling 모드 ──────────────────────────────────────────────────────────────
if [[ "$TUNNEL_PROVIDER" == "polling" ]]; then
    echo "⏰ 폴링 모드: webhook 없이 30초마다 Linear를 폴링합니다."
    echo ""
    echo "   실행: python3 scripts/linear_watcher.py"
    echo "   백그라운드: python3 scripts/linear_watcher.py &"
    exit 0
fi

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
if [[ "$TUNNEL_PROVIDER" == "cloudflare" ]]; then
    echo "☁️  Cloudflare Tunnel 설정 중..."

    if ! command -v cloudflared &>/dev/null; then
        echo "   cloudflared 설치 중..."
        if [[ "$(uname)" == "Darwin" ]]; then
            if command -v brew &>/dev/null; then
                brew install cloudflare/cloudflare/cloudflared
            else
                echo "   ERROR: Homebrew가 필요합니다. https://brew.sh 설치 후 재시도."
                exit 1
            fi
        elif command -v apt-get &>/dev/null; then
            curl -L --output cloudflared.deb \
                https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64.deb
            sudo dpkg -i cloudflared.deb && rm cloudflared.deb
        elif command -v snap &>/dev/null; then
            sudo snap install cloudflared
        else
            echo "   ERROR: 지원되지 않는 OS입니다. https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/downloads/ 에서 수동 설치하세요."
            exit 1
        fi
    fi

    echo "   터널 기동 중 (포트 $WEBHOOK_PORT)..."
    # URL 파싱을 위해 임시 로그 파일 사용
    TMP_LOG=$(mktemp)
    cloudflared tunnel --url "http://localhost:$WEBHOOK_PORT" 2>"$TMP_LOG" &
    CF_PID=$!

    # URL 발급까지 최대 20초 대기
    TUNNEL_URL=""
    for _ in $(seq 1 40); do
        TUNNEL_URL=$(grep -oP 'https://[a-z0-9\-]+\.trycloudflare\.com' "$TMP_LOG" 2>/dev/null | head -1 || true)
        if [[ -n "$TUNNEL_URL" ]]; then
            break
        fi
        sleep 0.5
    done
    rm -f "$TMP_LOG"

    if [[ -z "$TUNNEL_URL" ]]; then
        echo "   ERROR: 터널 URL을 가져오지 못했습니다. cloudflared를 직접 실행해 확인하세요:"
        echo "   cloudflared tunnel --url http://localhost:$WEBHOOK_PORT"
        kill "$CF_PID" 2>/dev/null || true
        exit 1
    fi

    echo ""
    echo "   ✅ Cloudflare Tunnel URL: $TUNNEL_URL"
    _update_env "WEBHOOK_PUBLIC_URL" "$TUNNEL_URL"
    echo "   .env의 WEBHOOK_PUBLIC_URL을 업데이트했습니다."
    # PID 저장 (stop.sh / start.sh가 사용)
    echo "$CF_PID" > "$PROJECT_ROOT/.run/tunnel.pid"

    if [[ "$DETACH_MODE" -eq 1 ]]; then
        # --detach: URL을 파일에 기록하고 반환 (프로세스는 백그라운드에서 계속 실행)
        echo "$TUNNEL_URL" > "$PROJECT_ROOT/.run/tunnel.url"
        exit 0
    fi

    echo ""
    echo "   다음 단계:"
    echo "   1. ClickEye 설정 페이지에서 위 URL을 저장하세요 → Linear Webhook 자동 등록"
    echo "   2. bash scripts/start-webhook.sh  (새 터미널)"
    echo ""
    echo "   ⚠️  이 터미널을 닫으면 터널이 종료됩니다. 유지하거나 백그라운드로 실행하세요."
    wait "$CF_PID"
    exit 0
fi

# ── ngrok ─────────────────────────────────────────────────────────────────────
if [[ "$TUNNEL_PROVIDER" == "ngrok" ]]; then
    echo "🔗 ngrok 설정 중..."

    if ! command -v ngrok &>/dev/null; then
        echo "   ERROR: ngrok이 설치되어 있지 않습니다."
        echo "   설치: https://ngrok.com/download"
        echo "   설치 후 인증: ngrok config add-authtoken <TOKEN>"
        exit 1
    fi

    if [[ -n "${NGROK_AUTH_TOKEN:-}" ]]; then
        ngrok config add-authtoken "$NGROK_AUTH_TOKEN" 2>/dev/null || true
    fi

    TMP_LOG=$(mktemp)
    ngrok http "$WEBHOOK_PORT" --log=stdout 2>"$TMP_LOG" &
    NGROK_PID=$!

    TUNNEL_URL=""
    for _ in $(seq 1 40); do
        TUNNEL_URL=$(grep -oP 'https://[a-z0-9\-]+\.ngrok(-free)?\.app' "$TMP_LOG" 2>/dev/null | head -1 || true)
        if [[ -n "$TUNNEL_URL" ]]; then
            break
        fi
        # ngrok API로도 시도
        TUNNEL_URL=$(curl -s http://localhost:4040/api/tunnels 2>/dev/null \
            | grep -oP '"public_url":"https://[^"]+' | head -1 | cut -d'"' -f4 || true)
        if [[ -n "$TUNNEL_URL" ]]; then
            break
        fi
        sleep 0.5
    done
    rm -f "$TMP_LOG"

    if [[ -z "$TUNNEL_URL" ]]; then
        echo "   URL 자동 감지 실패. ngrok dashboard(http://localhost:4040)에서 URL을 확인하세요."
        wait "$NGROK_PID"
        exit 0
    fi

    echo ""
    echo "   ✅ ngrok URL: $TUNNEL_URL"
    _update_env "WEBHOOK_PUBLIC_URL" "$TUNNEL_URL"
    echo "   .env의 WEBHOOK_PUBLIC_URL을 업데이트했습니다."
    echo "$NGROK_PID" > "$PROJECT_ROOT/.run/tunnel.pid"

    if [[ "$DETACH_MODE" -eq 1 ]]; then
        echo "$TUNNEL_URL" > "$PROJECT_ROOT/.run/tunnel.url"
        exit 0
    fi

    echo ""
    echo "   ⚠️  ngrok 무료 플랜은 재시작마다 URL이 변경됩니다."
    echo ""
    echo "   다음 단계:"
    echo "   1. ClickEye 설정 페이지에서 위 URL을 저장하세요 → Linear Webhook 자동 등록"
    echo "   2. bash scripts/start-webhook.sh  (새 터미널)"
    wait "$NGROK_PID"
    exit 0
fi

echo "ERROR: 알 수 없는 TUNNEL_PROVIDER '$TUNNEL_PROVIDER'. cloudflare/ngrok/polling 중 선택하세요."
exit 1
