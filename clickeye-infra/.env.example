# ClickEye Docker Compose 환경변수 템플릿
# 사용법: cp .env.example .env 후 값 수정

# Database (PostgreSQL 16)
DATABASE_URL=postgresql+asyncpg://clickeye:devpassword@db:5432/clickeye
POSTGRES_DB=clickeye
POSTGRES_USER=clickeye
POSTGRES_PASSWORD=devpassword

# Redis 7
REDIS_URL=redis://redis:6379

# API
JWT_SECRET_KEY=change-this-in-production
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=true

# Temporal 오케스트레이션 (CE-296) — profiles: [temporal] 기동 시에만 사용
# 워커 서비스 토글(compose 에서 true 로 override, 로컬 실행 기본 off)
FEATURE_TEMPORAL=false
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=clickeye-default
# temporal 서버는 기존 db(postgres) 를 백엔드로 재사용 — 별도 자격증명 불필요

# 운영 패널(Ops Panel) — CE-305 (기본 비활성, PR-2~ 에서 사용)
# 마스터 킬스위치: false면 전 ops 엔드포인트 404·네비 숨김(무침습 롤아웃)
FEATURE_OPS_PANEL=false
# read-only Docker 소켓 프록시 내부 URL (호스트/외부 미노출, ops-net 전용, POST=0)
DOCKER_PROXY_URL=http://dockerproxy:2375
# 관리형 env 파일의 컨테이너 내부 경로(api 서비스에 ../managed 가 /app/managed 로 마운트됨)
MANAGED_ENV_PATH=/app/managed/api.env
# 포트 상태 프로브 대상(JSON 리스트 예시) — PR-2 에서 사용
# 예: OPS_PORT_TARGETS=[{"name":"api","host":"api","port":8000},{"name":"db","host":"db","port":5432}]
OPS_PORT_TARGETS=[]
# 컨테이너 상태 조회 대상 서비스명(JSON 리스트 예시) — PR-2 에서 사용
# 예: OPS_MANAGED_SERVICES=["clickeye-api","clickeye-db","clickeye-redis"]
OPS_MANAGED_SERVICES=[]
