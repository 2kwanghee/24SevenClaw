# clickeye-llm 환경변수 예시 (app/config.py 의 Settings 미러)
# 실제 값은 .env 로 복사해 사용. compose 는 environment 로 직접 주입한다.

# 앱
APP_NAME=ClickEye LLM
DEBUG=false
LOG_LEVEL=INFO

# ── ★모델 스위처블★ ──
# 호스트에서 도는 ollama. 컨테이너 → 호스트 접근은 host.docker.internal(compose extra_hosts).
# 로컬 직접 실행 시에는 http://localhost:11434 로 설정.
OLLAMA_BASE_URL=http://host.docker.internal:11434
# 생성 모델(소형 sLLM). 다른 모델로 교체하려면 이 값만 변경.
LLM_MODEL=phi3:mini
# 임베딩 모델 (Qdrant upsert 용).
EMBED_MODEL=nomic-embed-text

# ── 벡터 DB (Qdrant) ──
QDRANT_URL=http://qdrant:6333
