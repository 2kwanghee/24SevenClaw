# API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Temporal UI (딜리버리 콘솔 거버넌스 패널의 게이트 결정 이력 링크).
# 미설정 시 패널에서 링크를 숨긴다(빈/깨진 링크 방지).
NEXT_PUBLIC_TEMPORAL_URL=http://localhost:8080

# Auth.js
AUTH_SECRET=change-this-in-production
AUTH_URL=http://localhost:3000

# Feature flags
# ClickEye Modernize (기존 코드 현대화 파이프라인, MVP-2-A). 기본 false — 화이트리스트 베타.
NEXT_PUBLIC_FEATURE_MODERNIZE_ENABLED=false
